<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/nusapedia"
        android:contentDescription="Logo NusaPedia"
        android:scaleType="fitCenter" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="NusaPedia"
        android:textColor="#1B5E20"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Nusantara Ensiklopedia"
        android:textColor="#4F7F52"
        android:textSize="16sp" />

    <TextView
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Jelajahi hewan dan tumbuhan endemik Indonesia"
        android:textColor="#5F6F61"
        android:textSize="13sp" />

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="210dp"
        android:layout_height="8dp"
        android:layout_marginTop="34dp"
        android:indeterminate="true"
        android:indeterminateTint="#2E7D32" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Memuat data endemik..."
        android:textColor="#6A6A6A"
        android:textSize="12sp" />

</LinearLayout>