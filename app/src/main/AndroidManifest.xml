<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="NusaPedia"
        android:theme="@style/Theme.NusaPedia">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.NusaPedia.NoSplash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity android:name=".HomeActivity" />
        <activity android:name=".PencarianActivity" />
        <activity android:name=".DetailActivity" />
        <activity android:name=".FavoritActivity" />
        <activity android:name=".ProfilActivity" />

    </application>

</manifest>